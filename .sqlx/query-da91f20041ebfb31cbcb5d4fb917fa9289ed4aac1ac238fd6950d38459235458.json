  "db_name": "PostgreSQL",
  "query": "\n                SELECT\n                    id,\n                    event_type,\n                    identifier,\n                    application_id,\n                    application_name,\n                    ip_address,\n                    occurred_at\n                FROM auth_events\n                WHERE (occurred_at, id) < ($1, $2)\n                ORDER BY occurred_at DESC, id DESC\n                LIMIT $3\n            ",
